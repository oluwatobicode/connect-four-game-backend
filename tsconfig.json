{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "ESNext",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "outDir": "./dist"
  },
  "include": ["src/**/*", "generated/**/*", "prisma.config.ts"]
}
